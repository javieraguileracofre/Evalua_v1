# Copiar a .env y completar valores reales.

# Para iPhone / tablet en la misma Wi‑Fi: dejar 0.0.0.0 (valor por defecto si no defines la variable).
# Solo esta PC: UVICORN_HOST=127.0.0.1
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000

APP_NAME=EvaluaERP
APP_ENV=development
APP_DEBUG=true
APP_VERSION=1.0.0
LOG_LEVEL=INFO
# Sesión web (Starlette): en producción use al menos 32 caracteres aleatorios (openssl rand -hex 32).
SECRET_KEY=cambia-esto-en-produccion
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Cookie de sesión solo HTTPS (por defecto true si APP_ENV no es desarrollo).
# AUTH_COOKIE_SECURE=true
# Tiempo máximo de sesión en segundos (por defecto 28800 = 8 h).
# AUTH_SESSION_MAX_AGE_SECONDS=28800
# Timeout en segundos al conectar a PostgreSQL (evita carga infinita si la BD no responde).
# DB_CONNECT_TIMEOUT_SECONDS=10

# Opción A: URLs completas (recomendado si ya las tienes).
DATABASE_URL=postgresql+psycopg://usuario:clave@localhost:5432/nombre_bd
PLATFORM_DATABASE_URL=postgresql+psycopg://usuario:clave@localhost:5432/plataforma
#
# Render.com: el panel suele dar DATABASE_URL como postgres:// o postgresql://;
# la app convierte automáticamente a postgresql+psycopg. Ver render.yaml (Blueprint).
# Si el host es Supabase (*.supabase.co o pooler.supabase.com) y la URL no trae sslmode=,
# se añade sslmode=require (evita ConnectionTimeout al arrancar en Render).
# Supabase pooler transacción (6543), ejemplo: postgresql+psycopg://postgres.<REF>:clave@aws-....pooler.supabase.com:6543/postgres?sslmode=require
# Si pegas db.<REF>.supabase.co:5432 (panel «Direct»), en Render suele fallar por IPv6: la app la reescribe sola al pooler :6543 salvo SUPABASE_ALLOW_DIRECT_DB_URL=true.
# SUPABASE_POOLER_HOST / SUPABASE_POOLER_PORT si el panel muestra otro host/puerto del pooler.
# Producción en Render: APP_ENV=production, APP_DEBUG=false, AUTH_COOKIE_SECURE=true,
# SECRET_KEY con al menos 32 caracteres aleatorios.

# Opción B: variables sueltas (si no defines DATABASE_URL, se arma la URL automáticamente).
# Misma lógica para plataforma: si omites PLATFORM_DATABASE_URL, se usa la misma que DATABASE_URL.
# DB_USER=evalua_user
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=evaluaerp_db
# Supabase pooler transacción (ejemplo): DB_HOST=aws-....pooler.supabase.com DB_PORT=6543
#   DB_USER=postgres.<PROJECT_REF>  DB_SSLMODE=require
# Supabase u otro Postgres con SSL: DB_SSLMODE=require

# Opcional: scripts DDL (create_fin_ap_tables.py --use-admin-url); en Supabase suele ser la misma URI :6543
# ADMIN_POSTGRES_URL=postgresql+psycopg://postgres.<REF>:clave@aws-....pooler.supabase.com:6543/postgres?sslmode=require

DEFAULT_TENANT_CODE=athletic
# Si usas un solo Postgres (p. ej. Supabase) y aún no tienes fila en public.tenants:
# EVALUA_SINGLE_DB_TENANT=true
#
# Tras resetear la contraseña en Supabase: actualiza DATABASE_URL/PLATFORM en Render
# Y ejecuta tools/sql/sync_tenant_password_after_supabase_reset.sql (columna db_password en public.tenants).
TENANT_HEADER_NAME=X-Tenant-Code
TENANT_QUERY_PARAM=tenant
TENANT_COOKIE_NAME=tenant_code

# Fondos por rendir — códigos EXACTOS según su fin.plan_cuenta (recomendado en producción).
# Si omite estas líneas, el sistema intentará códigos habituales y nombres que contengan
# ANTICIPO, CAJA, GASTO, etc. Revise el asiento generado si usa búsqueda por nombre.
# FONDO_RENDIR_CUENTA_ANTICIPO=1.1.05
# FONDO_RENDIR_CUENTA_CAJA=1.1.01
# FONDO_RENDIR_CUENTA_GASTO=6.1.01
# Validar setup contable rápidamente:
#   python -m tools.healthcheck

# Nómina — códigos en fin.plan_cuenta (provisión + pago). REMUNERACION_CUENTA_GASTO_SUELDOS: gasto de personal (devengo).
# REMUNERACION_CUENTA_SUELDOS_POR_PAGAR=210101
# REMUNERACION_CUENTA_BANCO=110201
# REMUNERACION_CUENTA_GASTO_SUELDOS=610104
